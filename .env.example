# RelayPress environment

NODE_ENV=development
LOG_LEVEL=debug

# Public domains
RELAYPRESS_DOMAIN=relaypress.localhost
API_DOMAIN=api.relaypress.localhost
PUBLISHER_DOMAIN=app.relaypress.localhost
RELAY_DOMAIN=relay.relaypress.localhost

# Database
POSTGRES_DB=relaypress
POSTGRES_USER=relaypress
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://relaypress:change-me@postgres:5432/relaypress

# Queue / cache
REDIS_URL=redis://redis:6379

# Nostr
NOSTR_PRIVATE_RELAY=ws://strfry:7777
NOSTR_PUBLIC_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net
NOSTR_ALLOWED_PUBKEYS=
NOSTR_INDEX_ALL=false
NOSTR_LOOKBACK_SECONDS=3600

# Admin API
# Replace with a long random value before any exposed deployment.
ADMIN_API_TOKEN=change-me-admin-token

# Security
# Replace with long, random values. Do not commit real secrets.
TOKEN_ENCRYPTION_KEY=change-me-32-bytes-minimum
SESSION_SECRET=change-me

# AI providers
# AI_PROVIDER=openai enables OpenAI generation when OPENAI_API_KEY is present.
# Keep the key and model values in deployment environment only.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# Source ingestion
SOURCE_INGESTION_ENABLED=true
SOURCE_INGESTION_BATCH_SIZE=10
SOURCE_INGESTION_INTERVAL_MS=43200000
BTCBREAKDOWN_BASE_URL=https://www.btcbreakdown.com

# Publisher orchestration
# PR X0 only supports per-platform mock or disabled modes.
# Any real or unknown value is blocked and logged. No real social API is called.
LINKEDIN_PUBLISHER_MODE=mock
X_PUBLISHER_MODE=mock
FACEBOOK_PUBLISHER_MODE=mock
INSTAGRAM_PUBLISHER_MODE=disabled
NOSTR_PUBLISHER_MODE=mock
PUBLISHER_BATCH_SIZE=10
WORKER_TICK_INTERVAL_MS=30000

# Legacy global setting. Kept only for migration visibility and never arms real publication.
PUBLISHER_MODE=mock

# Future per-platform real publication safety acknowledgements.
# Keep empty until the dedicated real publisher PR for each platform.
LINKEDIN_REAL_SAFETY_ACK=
X_REAL_SAFETY_ACK=
META_REAL_SAFETY_ACK=
NOSTR_REAL_SAFETY_ACK=

# LinkedIn publisher / OAuth preparation
LINKEDIN_API_BASE_URL=https://api.linkedin.com/v2
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=https://api.relaypress.localhost/publisher-accounts/linkedin/oauth/callback
LINKEDIN_OAUTH_SCOPES=openid profile email w_member_social

# X / Meta publisher preparation
X_CLIENT_ID=
X_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=

# Observability
METRICS_ENABLED=true
METRICS_PORT=9100
