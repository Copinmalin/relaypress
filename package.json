{
  "name": "relaypress",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "Système éditorial souverain piloté par Nostr, IA et publication multi-plateforme",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter './packages/*' build && pnpm -r typecheck",
    "check": "pnpm typecheck && pnpm build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
